            </div>
            <div class="hero-visual">
                <div class="pouch-render" id="dynamicPouch">
                    <div class="pouch-brand">STEADY STATE</div>
                    <svg class="pouch-center-icon" viewBox="0 0 100 40" stroke="url(#metallic-gradient)" stroke-width="1.5" fill="none">
                        <path d="M5,20 L30,20 L38,10 L46,30 L54,15 L58,20 L70,20 C 70,20 73,12 80,20 C 87,28 78,32 78,20 Z" />
                    </svg>
