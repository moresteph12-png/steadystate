                        <div class="pouch-meta" id="pouchMeta">Sustained Clarity &amp; Bioavailable Protein</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container">
            <div class="hero-tagline" style="text-align: center; margin-bottom: 4rem;">Core System Pillars</div>
            <div class="pillars-grid">
                <div class="pillar-card">
                    <h3>Frictionless Utility</h3>
                    <p>Zero prep, zero cleanup, shelf-stable format achieved via advanced Retort Processing. Designed for seamless on-the-go extrusion.</p>
                </div>
                <div class="pillar-card">
                    <h3>Quiet Luxury Aesthetic</h3>
                    <p>Minimalist naming, clinical layout, and deep metallic visual identities beautifully tailored to look native in premium corporate environments.</p>
                </div>
                <div class="pillar-card">
                    <h3>Native Bioavailability</h3>
                    <p>High-solids Canterbury Milk Protein Isolate (MPI 90) perfectly balanced with premium native New Zealand functional botanicals.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="portfolio">
        <div class="container">
            <div class="hero-tagline" style="margin-bottom: 3rem;">Product Portfolio Matrix</div>
            <div class="matrix-layout">
                <div class="matrix-selector">
                    <div class="matrix-option active" onclick="switchProduct(1, 'No. 01 High Country Flat White', 'Madagascar vanilla bean extract, premium Canterbury dairy, and a 20g protein hit.', 'The everyday foundational routine; the direct substitute for the standard morning café run.', '#1E293B')">
