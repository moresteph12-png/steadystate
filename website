                        <h4>No. 02</h4>
                        <p>Black Sand Mocha</p>
                    </div>
                    <div class="matrix-option" onclick="switchProduct(3, 'No. 03 Dusky Sound Chai', 'Ceylon cinnamon, cardamom, and a fractional percentage of native Horopito leaf liquid extract.', 'The atmospheric, spiced momentum profile; features a warm, wild heat for sustained cognitive drive.', '#111827')">
                        <h4>No. 03</h4>
                        <p>Dusky Sound Chai</p>
                    </div>
                </div>
                <div class="matrix-display">
                    <div>
                        <h3 class="matrix-display-title" id="displayTitle">No. 01 High Country Flat White</h3>
                        <p class="matrix-display-profile" id="displayProfile">Madagascar vanilla bean extract, premium Canterbury dairy, and a 20g protein hit.</p>
                        <div class="matrix-display-utility">
                            <h5>Target Persona Utility</h5>
                            <p id="displayUtility">The everyday foundational routine; the direct substitute for the standard morning café run.</p>
                        </div>
                    </div>
                    <div class="matrix-stats">
                        <div class="stat-block">
                            <span class="stat-val">20g</span>
                            <span class="stat-lbl">Protein</span>
                        </div>
                        <div class="stat-block">
                            <span class="stat-val">130g</span>
                            <span class="stat-lbl">Pouch Vol</span>
                        </div>
                        <div class="stat-block">
                            <span class="stat-val">Zero</span>
                            <span class="stat-lbl">Sugar Crash</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="formulation">
        <div class="container">
            <div class="hero-tagline">Industrial Formulation Matrix</div>
            <h2 style="margin-bottom: 1rem; font-weight: 300;">Beta-Matrix Structure (Per 130g Pouch)</h2>
            <p style="color: var(--text-muted); max-width: 600px;">Engineered via a specialized hydrocolloid stabilizer system to ensure a completely smooth, pudding-like consistency suitable for direct pouch extrusion without protein curdling.</p>
            
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Ingredient</th>
                            <th>Percentage (%)</th>
                            <th>Functional Purpose</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Filtered Water</td>
                            <td>45.0%</td>
                            <td>Hydration base</td>
                        </tr>
                        <tr>
                            <td>Canterbury Milk Protein Isolate (MPI 90)</td>
                            <td>17.5%</td>
                            <td>Primary bioavailable protein source; low lactose</td>
                        </tr>
                        <tr>
                            <td>Cold Brew Arabica Concentrate (20 Brix)</td>
                            <td>15.0%</td>
                            <td>Caffeine source; high-solids to limit water volume</td>
                        </tr>
