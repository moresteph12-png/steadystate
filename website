                        </tr>
                        <tr>
                            <td>Sunflower Lecithin (Liquid)</td>
                            <td>0.8%</td>
                            <td>Emulsifier to bind water and dairy fats</td>
                        </tr>
                        <tr>
                            <td>Stabilizer Blend (Gellan Gum &amp; Cellulose Gel)</td>
                            <td>0.4%</td>
                            <td>Suspends protein; provides smooth flow and paste texture</td>
                        </tr>
                        <tr>
                            <td>Sodium Phosphate</td>
                            <td>0.3%</td>
                            <td>Buffer to prevent protein curdling in acidic coffee</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <footer>
        <div class="container footer-grid">
            <div>&copy; 2026 Steady State. All Rights Reserved.</div>
            <div style="letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem;">Clinical Precision // Quiet Luxury</div>
        </div>
    </footer>

    <script>
        function switchProduct(num, name, profile, utility, color) {
            // Update active state classes in UI matrix selectors
            const options = document.querySelectorAll('.matrix-option');
            options.forEach((opt, index) => {
                if (index === num - 1) opt.classList.add('active');
                else opt.classList.remove('active');
            });

            // Update Main Content Blocks Dynamically
            document.getElementById('displayTitle').innerText = name;
            document.getElementById('displayProfile').innerText = profile;
            document.getElementById('displayUtility').innerText = utility;

            // Live Pouch Mockup Syncing updates
            document.getElementById('pouchTitle').innerText = name;
            
            const pouch = document.getElementById('dynamicPouch');
            pouch.style.transform = "scale(0.96) rotate(-2deg)";
            
            setTimeout(() => {
                pouch.style.transform = "scale(1) rotate(0deg)";
            }, 200);
        }
    </script>
</body>
</html>
