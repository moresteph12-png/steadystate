    </svg>

    <header>
        <div class="container nav-container">
            <a href="#" class="brand-logo">
                <svg class="logo-icon" viewBox="0 0 100 40">
                    <path d="M5,20 L30,20 L38,10 L46,30 L54,15 L58,20 L70,20 C 70,20 73,12 80,20 C 87,28 78,32 78,20 Z" />
